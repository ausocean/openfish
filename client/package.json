{
  "name": "@openfish/client",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "generate:openapi": "swag init --dir ../cmd/openfish --output . --outputTypes json --v3.1",
    "generate:ts": "openapi-typescript swagger.json -o schema.ts --properties-required-by-default",
    "fmt": "biome format . --write",
    "check": "biome check . --write",
    "ci:fmt": "biome ci --formatter-enabled=true --reporter=github .",
    "ci:check": "biome ci --linter-enabled=true --reporter=github ."
  }
}
